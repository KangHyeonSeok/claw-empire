# Keep local secrets and env files out of Docker build context
.env
.env.*
!.env.example

# Git metadata
.git/
.github/
.gitignore

# Local/runtime artifacts
node_modules/
data/
logs/
coverage/
playwright-report/
test-results/
*.log
*.pid
*.sqlite
*.sqlite-shm
*.sqlite-wal
*.sqlite-journal

# Build/test caches
dist/
.tmp/
*.tsbuildinfo

# Local docker runtime secrets
deploy/docker/*.env
deploy/docker/runtime/

# OS/editor noise
.DS_Store
.vscode/
.idea/
